# =============================================================================
# =============================================================================
# Clinical AI Assistant — .gitignore
# =============================================================================

# ── Secrets & environment ─────────────────────────────────────────────────────
.env
*.env
!.env.example          # keep the template, never the real keys

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.so

# Virtual environments
.venv/
venv/
env/
ENV/
.Python

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
MANIFEST

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Testing & coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.hypothesis/

# ── Type checkers ────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/

# ── Pipeline outputs ──────────────────────────────────────────────────────────
*_clinical_output.json
clinical_chunks_*/

# ── Audio / temp files ────────────────────────────────────────────────────────
*.mp3
*.wav
*.flac
*.ogg
*.m4a
!sample/             # uncomment if you add a sample/ folder you DO want tracked

# ── Video / VOD files ─────────────────────────────────────────────────────────
*.mp4
*.mov
*.avi
*.mkv
*.webm
*.m4v
*.ts

# ── Extracted audio intermediates ─────────────────────────────────────────────
clinical_video_*/
*_extracted.mp3

# ── ML model caches ───────────────────────────────────────────────────────────
# pyannote / HuggingFace cache (usually in ~/.cache, but guard local copies)
models/
*.bin
*.pt
*.pth
*.ckpt
*.safetensors

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~
.idea/
.vscode/
*.suo
*.user
# =============================================================================
# Frontend / JS Ignore
# =============================================================================
# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.sw?
