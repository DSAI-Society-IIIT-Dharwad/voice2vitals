# ─────────────────────────────────────────────────────────────────────────────
# Clinical AI Assistant — Environment Variables
# Copy this file to `.env` (same folder as clinical_ai_assistant.py) and fill in
# your real keys. The script will auto-load it via python-dotenv.
# ─────────────────────────────────────────────────────────────────────────────

# Groq API key — https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Hugging Face user access token — https://huggingface.co/settings/tokens
# Required to download the gated pyannote/speaker-diarization-3.1 model.
# You must also accept the model's terms at:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
